---
/*
  Pictos des 4 valeurs — recréation vectorielle des icônes du logo client
  (design/Logo&visuels.jpeg) : trait monoline arrondi, couleur héritée
  via currentColor.
*/
interface Props {
  name: "volant" | "coeur" | "route" | "liberte";
  class?: string;
}
const { name, class: className = "h-7 w-7" } = Astro.props;
---

{
  name === "volant" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="8.5" />
      <circle cx="12" cy="12" r="2.1" />
      <path d="M3.5 12h6.4M14.1 12h6.4M12 14.1v6.4" />
    </svg>
  )
}
{
  name === "coeur" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 20.6c-3.9-3-6.6-5.5-6.6-8.4C5.4 9.9 7 8.4 9 8.4c1.1 0 2.2.5 3 1.4.8-.9 1.9-1.4 3-1.4 2 0 3.6 1.5 3.6 3.8 0 2.9-2.7 5.4-6.6 8.4z" />
      <path d="M12 2v1.8M5.2 4.2l1.2 1.3M18.8 4.2l-1.2 1.3M2 10.5l1.8.3M22 10.5l-1.8.3" />
    </svg>
  )
}
{
  name === "route" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="14" cy="6.8" r="2.2" />
      <path d="M14 2.4v1.1M10.4 3.4l.8.9M17.6 3.4l-.8.9M9.4 6.8h1.5M18.6 6.8h-1.5" />
      <path d="M3.5 21c3.5-3.5 5-7 8-10.2M11 21c2.5-3 3-6.8 4-10" />
      <path d="M8.6 17.6l1-1.1" />
    </svg>
  )
}
{
  name === "liberte" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="4.7" r="1.9" />
      <path d="M5.5 8.2c2.5 2.4 4.5 3.2 6.5 3.2s4-.8 6.5-3.2" />
      <path d="M12 11.4c-1.2 2.6-1.4 5.1-2 8.1M12 11.4c1.2 2.6 1.4 5.1 2 8.1" />
    </svg>
  )
}
