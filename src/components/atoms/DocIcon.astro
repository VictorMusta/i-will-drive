---
/*
  Atom — pictos des pièces d'inscription (flyer « Pièces nécessaires
  à l'inscription ») : identité, domicile, photo, ASSR, JDC, règlement.
  Monoline arrondi, currentColor.
*/
import type { DocIconName } from "../../consts";

interface Props {
  name: DocIconName;
  class?: string;
}
const { name, class: className = "h-6 w-6" } = Astro.props;
---

{
  name === "identite" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="5.5" width="18" height="13" rx="2.5" />
      <circle cx="8.6" cy="10.6" r="1.9" />
      <path d="M5.8 15.6c.5-1.6 1.5-2.4 2.8-2.4s2.3.8 2.8 2.4M14.5 9.5h4M14.5 12.5h4M14.5 15.5h2.5" />
    </svg>
  )
}
{
  name === "domicile" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4.5 10.5L12 4l7.5 6.5" />
      <path d="M6.5 9.5V19h11V9.5" />
      <path d="M10 19v-4.5h4V19" />
    </svg>
  )
}
{
  name === "photo" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="4.5" y="4" width="15" height="16" rx="2" />
      <circle cx="12" cy="10" r="2.4" />
      <path d="M7.5 17.5c.7-2.2 2.4-3.3 4.5-3.3s3.8 1.1 4.5 3.3" />
    </svg>
  )
}
{
  name === "assr" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 3.5h8.5L19 8v12.5H6z" />
      <path d="M14 3.5V8.5h5" />
      <path d="M9 12.5h6M9 15.5h6M9 18h3.5" />
    </svg>
  )
}
{
  name === "jdc" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M6 3.5h8.5L19 8v12.5H6z" />
      <path d="M14 3.5V8.5h5" />
      <path d="M9.2 14.8l2 2 3.6-3.9" />
    </svg>
  )
}
{
  name === "reglement" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <ellipse cx="10" cy="7" rx="6" ry="2.6" />
      <path d="M4 7v5c0 1.4 2.7 2.6 6 2.6s6-1.2 6-2.6V7" />
      <path d="M4 12v5c0 1.4 2.7 2.6 6 2.6 1.2 0 2.3-.15 3.2-.4" />
      <path d="M17.8 15.2a3.2 3.2 0 1 0 2.4 3.85" />
      <path d="M15.8 17.6h3.6M15.8 19.2h3" />
    </svg>
  )
}
