---
/*
  Atom — pictos des cartes bénéfices (maquette finale) :
  calendrier, personne, euro, bouclier. Monoline arrondi, currentColor.
*/
interface Props {
  name: "calendrier" | "personne" | "euro" | "bouclier";
  class?: string;
}
const { name, class: className = "h-6 w-6" } = Astro.props;
---

{
  name === "calendrier" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="4" y="5.5" width="16" height="14" rx="3" />
      <path d="M4 10h16M8.5 3.5v3.5M15.5 3.5v3.5" />
      <path d="M8.5 14h2M13.5 14h2M8.5 16.8h2" />
    </svg>
  )
}
{
  name === "personne" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="8" r="3.2" />
      <path d="M5.5 20c.5-3.6 3-5.6 6.5-5.6s6 2 6.5 5.6" />
    </svg>
  )
}
{
  name === "euro" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M17.5 6.5A6.5 6.5 0 0 0 8 12a6.5 6.5 0 0 0 9.5 5.5" />
      <path d="M5 10.3h7M5 13.7h6" />
    </svg>
  )
}
{
  name === "bouclier" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3.5l7 2.5v5.2c0 4.4-2.9 7.6-7 9.3-4.1-1.7-7-4.9-7-9.3V6z" />
      <path d="M9 11.8l2.2 2.2 4-4.3" />
    </svg>
  )
}
