---
/*
  Pictos des 4 valeurs — recréation vectorielle des icônes de la planche
  client (design/DA_2.jpeg) : cœur, deux personnes, soleil, papillon.
  Trait monoline arrondi, couleur héritée via currentColor.
  Contrainte client : aucun symbole automobile (volant, route, compteur…) —
  la voiture n'apparaît que dans la silhouette du logo officiel.
*/
interface Props {
  name: "coeur" | "personnes" | "soleil" | "papillon";
  class?: string;
}
const { name, class: className = "h-8 w-8" } = Astro.props;
---

{
  name === "coeur" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 19.6c-4-3-6.8-5.5-6.8-8.6C5.2 8.6 6.9 7 9 7c1.2 0 2.3.5 3 1.5.7-1 1.8-1.5 3-1.5 2.1 0 3.8 1.6 3.8 4 0 3.1-2.8 5.6-6.8 8.6z" />
    </svg>
  )
}
{
  name === "personnes" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="9" cy="8" r="2.7" />
      <path d="M4.3 19c.4-3 2.3-4.7 4.7-4.7s4.3 1.7 4.7 4.7" />
      <circle cx="16.5" cy="7.3" r="2.2" />
      <path d="M15.6 12.6c2.4.2 3.9 1.9 4.2 4.6" />
    </svg>
  )
}
{
  name === "soleil" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="3.6" />
      <path d="M12 3.2v2M12 18.8v2M3.2 12h2M18.8 12h2M5.8 5.8l1.4 1.4M16.8 16.8l1.4 1.4M18.2 5.8l-1.4 1.4M7.2 16.8l-1.4 1.4" />
    </svg>
  )
}
{
  name === "papillon" && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 8.8v8.2" />
      <path d="M12 8.8c-.7-1.2-1.4-1.9-2.2-2.4M12 8.8c.7-1.2 1.4-1.9 2.2-2.4" />
      <path d="M11.5 10.5C9 7.8 5.6 8 5.2 10.2c-.3 1.8 1.4 3 4.1 2.7" />
      <path d="M9.3 12.9c-2.5.4-3.6 2.1-2.7 3.5.9 1.4 3.3 1 4.9-1.8" />
      <path d="M12.5 10.5c2.5-2.7 5.9-2.5 6.3-.3.3 1.8-1.4 3-4.1 2.7" />
      <path d="M14.7 12.9c2.5.4 3.6 2.1 2.7 3.5-.9 1.4-3.3 1-4.9-1.8" />
    </svg>
  )
}
