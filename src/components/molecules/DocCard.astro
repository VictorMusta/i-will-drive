---
/*
  Molecule — pièce à fournir pour l'inscription (flyer client) :
  numéro, pastille d'icône pastel, titre, description.
*/
import DocIcon from "../atoms/DocIcon.astro";
import type { INSCRIPTION_DOCS } from "../../consts";

interface Props {
  doc: (typeof INSCRIPTION_DOCS)[number];
  index: number;
}
const { doc, index } = Astro.props;
---

<article class="flex items-start gap-4 rounded-2xl border border-hairline bg-surface p-5">
  <span
    class="grid h-14 w-14 flex-none place-items-center rounded-full"
    style={`background: color-mix(in srgb, ${doc.color} 13%, white); color: ${doc.color}`}
    aria-hidden="true"
  >
    <DocIcon name={doc.icon} class="h-7 w-7" />
  </span>
  <div>
    <h3 class="font-extrabold">
      <span class="font-display text-lg" style={`color: ${doc.color}`}>{index}.</span>
      {doc.title}
    </h3>
    <p class="mt-1 text-sm text-muted">{doc.desc}</p>
  </div>
</article>
