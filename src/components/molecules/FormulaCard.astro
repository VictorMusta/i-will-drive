---
import type { Formula } from "../../consts";
import { SITE } from "../../consts";
import Button from "../atoms/Button.astro";

interface Props {
  formula: Formula;
}
const { formula } = Astro.props;
---

<article
  class:list={[
    "flex flex-col gap-4 rounded-2xl border bg-surface p-6",
    formula.featured ? "border-accent shadow-[0_14px_30px_rgba(11,18,32,0.08)]" : "border-hairline",
  ]}
>
  {
    formula.tag && (
      <span
        class="self-start rounded-full px-2.5 py-1 text-[0.68rem] font-extrabold uppercase tracking-[0.12em]"
        style="background: color-mix(in srgb, var(--color-accent) 12%, transparent); color: var(--color-accent-deep)"
      >
        {formula.tag}
      </span>
    )
  }

  <h3 class="text-xl font-extrabold">{formula.title}</h3>

  <div class="text-4xl font-extrabold tracking-tight">
    {formula.price}
    <span class="text-sm font-semibold text-muted">/ {formula.unit}</span>
  </div>

  <ul class="flex flex-col gap-2.5">
    {
      formula.features.map((f) => (
        <li class="flex items-start gap-2.5 text-[0.95rem]">
          <svg
            class="mt-0.5 flex-none"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="12" fill="var(--color-go)" />
            <path d="M9 16.2 4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4z" fill="white" transform="scale(0.62) translate(7.3 7.3)" />
          </svg>
          <span>{f}</span>
        </li>
      ))
    }
  </ul>

  <Button href={SITE.elgeaUrl} external variant={formula.variant} class="mt-auto w-full">
    {formula.cta} <span class="arrow" aria-hidden="true">→</span>
  </Button>
</article>
