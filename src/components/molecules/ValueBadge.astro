---
/*
  Molecule — une valeur de la marque : picto + label, desc optionnelle.
  compact : picto + label sur une ligne (hero, maquette finale).
  détaillé : colonne centrée avec la promesse (section Bienvenue).
*/
import ValueIcon from "../atoms/ValueIcon.astro";
import type { VALUES } from "../../consts";

interface Props {
  value: (typeof VALUES)[number];
  compact?: boolean;
}
const { value, compact = false } = Astro.props;
---

{
  compact ? (
    <span class="inline-flex flex-col items-center gap-1.5" style={`color: ${value.color}`}>
      <ValueIcon name={value.icon} class="h-7 w-7" />
      <span class="text-xs font-bold uppercase tracking-[0.12em] text-ink">{value.label}</span>
    </span>
  ) : (
    <div class="flex flex-col items-center gap-2.5 text-center">
      <span style={`color: ${value.color}`}>
        <ValueIcon name={value.icon} class="h-8 w-8" />
      </span>
      <span class="text-sm font-bold uppercase tracking-[0.14em]" style={`color: ${value.color}`}>
        {value.label}
      </span>
      <p class="max-w-[26ch] text-sm text-muted">{value.desc}</p>
    </div>
  )
}
