---
/*
  Molecule — une valeur de la marque : picto + label, desc optionnelle.
  compact : picto + label sur une ligne (hero, maquette p.1).
  carte : carte blanche, pastille ronde colorée, promesse, tiret couleur
  (maquette p.2 « Pourquoi choisir i will drive ? »).
*/
import ValueIcon from "../atoms/ValueIcon.astro";
import type { VALUES } from "../../consts";

interface Props {
  value: (typeof VALUES)[number];
  compact?: boolean;
}
const { value, compact = false } = Astro.props;
---

{
  compact ? (
    <span class="inline-flex flex-col items-center gap-1.5" style={`color: ${value.color}`}>
      <ValueIcon name={value.icon} class="h-7 w-7" />
      <span class="text-xs font-bold uppercase tracking-[0.12em] text-ink">{value.label}</span>
    </span>
  ) : (
    <div class="flex flex-col items-center gap-3 rounded-2xl border border-hairline bg-surface p-6 text-center">
      <span
        class="grid h-14 w-14 place-items-center rounded-full"
        style={`background: color-mix(in srgb, ${value.color} 14%, white); color: ${value.color}`}
      >
        <ValueIcon name={value.icon} class="h-7 w-7" />
      </span>
      <span class="text-base font-extrabold" style={`color: ${value.color}`}>
        {value.label}
      </span>
      <p class="text-sm text-muted">{value.desc}</p>
      <span class="mt-auto h-1 w-8 rounded-full" style={`background: ${value.color}`} aria-hidden="true" />
    </div>
  )
}
