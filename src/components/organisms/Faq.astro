---
/*
  Organism — questions fréquentes.
*/
import FaqItem from "../molecules/FaqItem.astro";
import { FAQ } from "../../consts";
---

<section class="container-x py-20 md:py-28">
  <p class="label">06 — Questions fréquentes</p>
  <h2 class="mt-2 text-3xl font-extrabold md:text-5xl">Bon à savoir</h2>

  <div class="mx-auto mt-10 flex max-w-3xl flex-col gap-3">
    {FAQ.map((item) => <FaqItem item={item} />)}
  </div>
</section>
