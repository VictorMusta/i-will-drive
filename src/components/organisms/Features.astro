---
/*
  Organism — les 4 cartes bénéfices de la maquette finale, dans le
  prolongement du bas du mesh du hero.
*/
import FeatureCard from "../molecules/FeatureCard.astro";
import { FEATURES } from "../../consts";
---

<section>
  <div class="container-x grid gap-6 py-14 sm:grid-cols-2 lg:grid-cols-4">
    {FEATURES.map((feature) => <FeatureCard feature={feature} />)}
  </div>
</section>
