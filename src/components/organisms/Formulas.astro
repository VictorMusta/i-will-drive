---
/*
  Organism — « Nos formations & tarifs » (maquette p.3, tarifs officiels) :
  formations proposées, tableau Pack Permis B tout compris,
  prestations à l'unité et autres formations.
*/
import Button from "../atoms/Button.astro";
import { SITE, FORMATIONS, PACKS, UNIT_PRICES, OTHER_FORMATIONS } from "../../consts";
---

<section id="formations" class="bg-veil border-y border-hairline py-20 md:py-28">
  <div class="container-x">
    <p class="label">02 — Formations & tarifs</p>
    <h2 class="mt-2 text-3xl font-extrabold md:text-5xl">Nos formations & tarifs</h2>
    <p class="mt-4 max-w-[60ch] text-lg text-muted">
      Des tarifs clairs, tout compris, sans frais cachés. Réservation et
      paiement en ligne depuis votre espace élève.
    </p>

    <!-- Formations proposées -->
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        FORMATIONS.map((f) => (
          <div class="rounded-2xl border border-hairline bg-ground p-5">
            <h3 class="font-extrabold" style={`color: ${f.color}`}>{f.title}</h3>
            <p class="mt-1.5 text-sm text-muted">{f.desc}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-10 grid gap-8 lg:grid-cols-[1.5fr_1fr] lg:items-start">
      <!-- Tableau Pack Permis B -->
      <div class="overflow-hidden rounded-2xl border border-hairline bg-ground shadow-[0_10px_24px_rgba(20,33,61,0.05)]">
        <div
          class="px-6 py-4 text-center text-on-accent"
          style="background: linear-gradient(90deg, var(--color-accent), var(--color-teal))"
        >
          <h3 class="text-lg font-extrabold uppercase tracking-wide">Pack Permis B</h3>
          <p class="text-xs font-bold uppercase tracking-[0.16em] opacity-90">Tout compris</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm" style="font-variant-numeric: tabular-nums">
            <thead>
              <tr>
                <th class="p-3 text-left font-semibold text-muted sr-only">Prestation</th>
                {
                  PACKS.columns.map((col) => (
                    <th class="p-3 text-center font-extrabold" style={`color: ${col.color}`}>
                      {col.name.replace("Pack ", "")}
                      <span class="block text-[0.65rem] font-bold uppercase tracking-[0.14em] text-muted">Pack</span>
                    </th>
                  ))
                }
              </tr>
            </thead>
            <tbody>
              {
                PACKS.rows.map((row) => (
                  <tr class="border-t border-hairline">
                    <th scope="row" class="p-3 text-left font-semibold">{row.label}</th>
                    {row.values.map((v, i) => (
                      <td
                        class:list={["p-3 text-center", v === "✓" ? "font-extrabold" : ""]}
                        style={v === "✓" ? `color: ${PACKS.columns[i].color}` : undefined}
                      >
                        {v}
                      </td>
                    ))}
                  </tr>
                ))
              }
              <tr class="border-t-2 border-hairline bg-surface">
                <th scope="row" class="p-3 text-left text-base font-extrabold">Prix total</th>
                {
                  PACKS.totals.map((total, i) => (
                    <td class="p-3 text-center text-lg font-extrabold" style={`color: ${PACKS.columns[i].color}`}>
                      {total}
                    </td>
                  ))
                }
              </tr>
            </tbody>
          </table>
        </div>
        <p class="border-t border-hairline px-6 py-3 text-sm font-semibold text-muted">
          💳 {PACKS.paymentNote}
        </p>
      </div>

      <div class="flex flex-col gap-6">
        <!-- À l'unité -->
        <div class="overflow-hidden rounded-2xl border border-hairline bg-ground">
          <h3
            class="px-5 py-3 text-sm font-extrabold uppercase tracking-[0.14em] text-on-accent"
            style="background: linear-gradient(90deg, var(--color-accent), var(--color-teal))"
          >
            À l'unité
          </h3>
          <ul class="divide-y divide-hairline" style="font-variant-numeric: tabular-nums">
            {
              UNIT_PRICES.map((u) => (
                <li class="flex items-center justify-between gap-4 px-5 py-3 text-sm">
                  <span>{u.label}</span>
                  <span class="font-extrabold">{u.price}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Autres formations -->
        <div class="overflow-hidden rounded-2xl border border-hairline bg-ground">
          <h3
            class="px-5 py-3 text-sm font-extrabold uppercase tracking-[0.14em] text-on-accent"
            style="background: linear-gradient(90deg, var(--color-teal), #7C5CBF)"
          >
            Autres formations
          </h3>
          <ul class="divide-y divide-hairline" style="font-variant-numeric: tabular-nums">
            {
              OTHER_FORMATIONS.map((o) => (
                <li class="flex items-center justify-between gap-4 px-5 py-3 text-sm">
                  <span>
                    {o.label}
                    {o.note && <span class="block text-xs text-muted">({o.note})</span>}
                  </span>
                  <span class="whitespace-nowrap font-extrabold">{o.price}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <Button href={SITE.elgeaUrl} external class="w-full">
          Réserver ma leçon <span class="arrow" aria-hidden="true">→</span>
        </Button>
      </div>
    </div>
  </div>
</section>
