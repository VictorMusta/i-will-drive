---
import { Image } from "astro:assets";
import { NAV, SITE } from "../../consts";
import Button from "../atoms/Button.astro";
import logoTransparent from "../../assets/logo-transparent.png";
---

<header
  class="sticky top-0 z-40 border-b border-hairline/50 bg-ground/25 backdrop-blur-md"
>
  <div class="container-x flex items-center gap-4 py-2">
    <a href="#top" class="flex-none" aria-label={`${SITE.name} — accueil`}>
      <Image
        src={logoTransparent}
        alt={`Logo ${SITE.name}`}
        class="h-[72px] w-auto md:h-[84px]"
        widths={[192, 384]}
        sizes="176px"
        loading="eager"
      />
    </a>

    <nav class="ml-auto hidden items-center gap-7 md:flex" aria-label="Navigation principale">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="text-sm font-semibold text-muted transition-colors hover:text-ink"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <Button href="#rendezvous" class="ml-auto md:ml-0 !px-4 !py-2.5 text-sm">
      Réserver en ligne <span class="arrow" aria-hidden="true">→</span>
    </Button>
  </div>
</header>
