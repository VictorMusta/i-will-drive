---
import { NAV, SITE } from "../../consts";
import Wordmark from "../atoms/Wordmark.astro";
import Button from "../atoms/Button.astro";
---

<header
  class="sticky top-0 z-40 border-b border-hairline bg-ground/90 backdrop-blur-md"
>
  <div class="container-x flex items-center gap-4 py-3">
    <a href="#top" class="text-xl text-ink" aria-label={`${SITE.name} — accueil`}>
      <Wordmark />
    </a>

    <nav class="ml-auto hidden items-center gap-7 md:flex" aria-label="Navigation principale">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class="text-sm font-semibold text-muted transition-colors hover:text-ink"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <Button href={SITE.elgeaUrl} external class="ml-auto md:ml-0 !px-4 !py-2.5 text-sm">
      Réserver en ligne <span class="arrow" aria-hidden="true">→</span>
    </Button>
  </div>
</header>
