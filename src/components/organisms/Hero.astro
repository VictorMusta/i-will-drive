---
/*
  Organism — hero de la maquette finale : fond mesh clair, titre bleu profond
  avec « conduire. » arc-en-ciel, tirets de marque, valeurs compactes,
  CTA dégradé, icône seule (logo officiel) à droite.
*/
import { Image } from "astro:assets";
import Button from "../atoms/Button.astro";
import BrandDashes from "../atoms/BrandDashes.astro";
import ValueBadge from "../molecules/ValueBadge.astro";
import { SITE, VALUES } from "../../consts";
import iconeSeule from "../../assets/icone-seule.jpeg";
---

<section class="bg-mesh relative overflow-hidden">
  <div class="container-x grid items-center gap-10 py-16 md:grid-cols-[1.15fr_0.85fr] md:py-24">
    <div>
      <p class="label" style="color: var(--color-accent-deep)">Auto-école · Dordogne</p>

      <h1 class="mt-4 max-w-[13ch] text-5xl font-extrabold leading-[1.04] text-ink md:text-7xl">
        Vous allez
        <span class="text-rainbow">conduire</span><span style="color: var(--color-accent)">.</span>
      </h1>

      <BrandDashes class="mt-5" />

      <p class="mt-5 max-w-[46ch] text-lg text-muted">
        {SITE.tagline} Avec un enseignant qui prend le temps, réservation en
        ligne et suivi de vos heures — tout au même endroit.
      </p>

      <div class="mt-7 flex flex-wrap items-start gap-x-8 gap-y-4">
        {VALUES.map((value) => <ValueBadge value={value} compact />)}
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <Button href={SITE.elgeaUrl} external>
          Réserver ma leçon <span class="arrow" aria-hidden="true">→</span>
        </Button>
        <Button href={SITE.elgeaUrl} external variant="ghost" class="text-ink">
          Mon espace élève
        </Button>
      </div>
    </div>

    <!-- Icône seule — logo officiel (seule évocation autorisée de la voiture) -->
    <Image
      src={iconeSeule}
      alt={`Logo ${SITE.name} — soleil levant et silhouette`}
      class="mx-auto hidden w-full max-w-sm md:block lg:max-w-md"
      style="mix-blend-mode: multiply"
      widths={[416, 832]}
      sizes="(min-width: 1024px) 448px, 384px"
      loading="eager"
    />
  </div>
</section>
