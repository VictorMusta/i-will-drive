---
/*
  Organism — « Pièces nécessaires à l'inscription » (flyer client,
  Permis Classique B) : les 6 documents + note « à savoir ».
*/
import DocCard from "../molecules/DocCard.astro";
import { INSCRIPTION_DOCS, INSCRIPTION_NOTE } from "../../consts";
---

<section id="inscription" class="container-x py-20 md:py-28">
  <p class="label">03 — Inscription</p>
  <h2 class="mt-2 max-w-[22ch] text-3xl font-extrabold md:text-5xl">
    Pièces nécessaires à l'inscription
  </h2>
  <p class="mt-4 max-w-[60ch] text-lg text-muted">
    <span
      class="mr-1 inline-block rounded-full px-3 py-1 font-script text-xl font-bold text-white"
      style="background: linear-gradient(90deg, var(--color-accent), var(--color-teal))"
    >Permis Classique (B)</span>
    Merci de fournir l'ensemble des pièces ci-dessous pour constituer votre
    dossier d'inscription.
  </p>

  <div class="mt-10 grid gap-4 md:grid-cols-2">
    {INSCRIPTION_DOCS.map((doc, i) => <DocCard doc={doc} index={i + 1} />)}
  </div>

  <div
    class="mx-auto mt-8 flex max-w-2xl items-start gap-3 rounded-2xl border p-5"
    style="border-color: var(--color-teal); background: color-mix(in srgb, var(--color-teal) 7%, white)"
  >
    <span
      class="grid h-8 w-8 flex-none place-items-center rounded-full font-display text-lg font-bold text-white"
      style="background: var(--color-teal)"
      aria-hidden="true"
    >i</span>
    <div>
      <h3 class="font-extrabold" style="color: var(--color-teal)">À savoir</h3>
      <p class="mt-0.5 text-sm text-muted">{INSCRIPTION_NOTE}</p>
    </div>
  </div>
</section>
