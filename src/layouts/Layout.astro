---
import "../styles/global.css";
import { Image } from "astro:assets";
import { SITE, THEME } from "../consts";
import background from "../assets/background.jpeg";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;

// Respecte le base path (démo GitHub Pages) comme la racine (Netlify).
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const schema = {
  "@context": "https://schema.org",
  "@type": "DrivingSchool",
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  email: SITE.email,
  telephone: SITE.phone,
  areaServed: SITE.zone,
  address: {
    "@type": "PostalAddress",
    addressLocality: SITE.city,
    addressRegion: "Dordogne",
    postalCode: "24350",
    addressCountry: "FR",
  },
};
---

<!doctype html>
<html lang="fr" data-theme={THEME === "solaire" ? undefined : THEME}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={SITE.url} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Polices -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Nunito:wght@400;600;700;800&family=Caveat:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <!-- Fond fixe : l'image BACKGROUND.jpeg du client (design/), littérale.
         Filtre saturate/contrast pour renforcer la pigmentation (demande client).
         La classe .bg-mesh reste en dessous comme filet de sécurité. -->
    <div class="bg-mesh bg-mesh-fixed" aria-hidden="true">
      <Image
        src={background}
        alt=""
        class="h-full w-full object-cover"
        style="filter: saturate(1.55) contrast(1.1)"
        widths={[1280, 1920, 2560]}
        sizes="100vw"
        quality={82}
        loading="eager"
      />
      <!-- Renfort couleur calé sur la maquette : halos étendus vers le
           centre, cœur pêche chaud, bandeau bas orange→rose.
           Les courbes du JPEG restent visibles dessous. -->
      <div
        class="absolute inset-0"
        style="background:
          radial-gradient(88% 92% at 92% 2%, color-mix(in srgb, #00BFAE 52%, transparent), transparent 76%),
          radial-gradient(82% 86% at 100% 88%, color-mix(in srgb, #EC5FA1 56%, transparent), transparent 74%),
          radial-gradient(80% 84% at 0% 100%, color-mix(in srgb, #FF9A3C 60%, transparent), transparent 72%),
          radial-gradient(70% 60% at 42% 48%, color-mix(in srgb, #FFD9A8 34%, transparent), transparent 70%),
          linear-gradient(to top, color-mix(in srgb, #FF8A5C 30%, transparent), transparent 22%);"
      ></div>
    </div>
    <slot />
  </body>
</html>
