---
import "../styles/global.css";
import { SITE, THEME } from "../consts";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;

// Respecte le base path (démo GitHub Pages) comme la racine (Netlify).
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const schema = {
  "@context": "https://schema.org",
  "@type": "DrivingSchool",
  name: SITE.name,
  description: SITE.description,
  url: SITE.url,
  email: SITE.email,
  telephone: SITE.phone,
  areaServed: SITE.zone,
  address: {
    "@type": "PostalAddress",
    addressLocality: SITE.city,
    addressRegion: "Dordogne",
    postalCode: "24350",
    addressCountry: "FR",
  },
};
---

<!doctype html>
<html lang="fr" data-theme={THEME === "solaire" ? undefined : THEME}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={SITE.url} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Polices -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Nunito:wght@400;600;700;800&family=Caveat:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <!-- Fond mesh fixe — reproduction SVG de l'image de référence client :
         halos de couleur + vagues translucides aux courbes visibles.
         La classe .bg-mesh reste en dessous comme filet de sécurité. -->
    <div class="bg-mesh bg-mesh-fixed" aria-hidden="true">
      <svg class="h-full w-full" viewBox="0 0 1536 1024" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="mesh-base" x1="0" y1="0" x2="0.3" y2="1">
            <stop offset="0" stop-color="#FFFDF8" />
            <stop offset="1" stop-color="#FFF2DE" />
          </linearGradient>
          <radialGradient id="mesh-warm" cx="0.35" cy="0.42" r="0.55">
            <stop offset="0" stop-color="#FFEBD0" stop-opacity="0.75" />
            <stop offset="1" stop-color="#FFEBD0" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="mesh-teal" cx="0.94" cy="0.06" r="0.42">
            <stop offset="0" stop-color="#5FD6C8" stop-opacity="0.85" />
            <stop offset="0.55" stop-color="#8AE2D6" stop-opacity="0.45" />
            <stop offset="1" stop-color="#8AE2D6" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="mesh-pink" cx="0.99" cy="0.94" r="0.4">
            <stop offset="0" stop-color="#F26FB8" stop-opacity="0.85" />
            <stop offset="0.55" stop-color="#F792C8" stop-opacity="0.45" />
            <stop offset="1" stop-color="#F792C8" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="mesh-orange" cx="0.02" cy="0.99" r="0.38">
            <stop offset="0" stop-color="#FF9A2E" stop-opacity="0.9" />
            <stop offset="0.55" stop-color="#FFB25C" stop-opacity="0.5" />
            <stop offset="1" stop-color="#FFB25C" stop-opacity="0" />
          </radialGradient>
        </defs>

        <!-- fond crème + halos -->
        <rect width="1536" height="1024" fill="url(#mesh-base)" />
        <rect width="1536" height="1024" fill="url(#mesh-warm)" />
        <rect width="1536" height="1024" fill="url(#mesh-teal)" />
        <rect width="1536" height="1024" fill="url(#mesh-pink)" />
        <rect width="1536" height="1024" fill="url(#mesh-orange)" />

        <!-- grande courbe blanche du côté droit (sur le turquoise et le rose) -->
        <path d="M1536 140 C1290 210 1160 420 1215 690 C1252 880 1395 1000 1536 1024 Z" fill="#FFFFFF" opacity="0.38" />
        <!-- seconde courbe droite, chevauchement -->
        <path d="M1536 520 C1345 555 1245 715 1288 1024 L1536 1024 Z" fill="#FFFFFF" opacity="0.3" />

        <!-- vague de dune crème au centre-bas (ligne de crête visible) -->
        <path d="M0 790 C300 705 560 645 840 665 C1010 678 1095 725 1160 810 L1160 1024 L0 1024 Z" fill="#F8E2C2" opacity="0.55" />

        <!-- crête de vague blanche sur le halo orange, en bas à gauche -->
        <path d="M0 885 C225 830 430 852 630 940 C715 977 770 1002 830 1024 L0 1024 Z" fill="#FFFFFF" opacity="0.4" />
      </svg>
    </div>
    <slot />
  </body>
</html>
